{
  "manifest_version": 3,
  "name": "SAM Scraper Bridge",
  "version": "1.0.0",
  "description": "Connects SAM Scraper bot to your real Chrome browser via CDP",

  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "scripting",
    "cookies"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "SAM Scraper Bridge",
    "default_popup": "sidepanel.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": [
        "https://titlesearch.afxllc.com/*",
        "http://localhost/*",
        "https://localhost/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}