{
  "manifest_version": 3,
  "name": "SAM Scraper Bridge",
  "version": "1.0.0",
  "description": "Connects SAM Scraper bot to your real Chrome browser via CDP",

  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "scripting",
    "cookies",
    "sidePanel"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_title": "SAM Scraper Bridge",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "content_scripts": [
    {
      "matches": ["https://titlesearch.afxllc.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}